{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,

    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,

    "moduleResolution": "node16",
    "resolveJsonModule": true,

    "types": ["node"]
  },

  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}