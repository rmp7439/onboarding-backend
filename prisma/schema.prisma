generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EmployeeStatus {
  PENDING
  APPROVED
  REJECTED
}

enum Gender {
  MALE
  FEMALE
}

enum DocumentType {
  AADHAAR
  PAN
  DRIVING_LICENSE
  BANK_PASSBOOK
  EDUCATION
  VOTER_ID
  DISCHARGE_BOOK
}

enum BloodGroup {
  A_POSITIVE
  A_NEGATIVE
  B_POSITIVE
  B_NEGATIVE
  AB_POSITIVE
  AB_NEGATIVE
  O_POSITIVE
  O_NEGATIVE
}

model Employee {
  id String @id @default(cuid())

  employeeCode String? @unique
  status EmployeeStatus @default(PENDING)

  firstName   String
  surname     String
  fatherName  String
  husbandName String?

  gender Gender
  bloodGroup BloodGroup

  dateOfBirth DateTime
  joiningDate DateTime

  mobile String @unique
  aadhaar String  @unique
  pan     String  @unique
  uan     String?
  esic    String?

  permanentAddress String
  currentAddress   String
  city             String
  state            String
  pinCode          String

  bankName      String
  accountNumber String
  ifsc          String
  branch        String
  micr          String

  emergencyName     String
  emergencyRelation String
  emergencyPhone    String

  documents Document[]

  uploadedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([firstName, surname])
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("ADMIN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Document {
  id               String   @id @default(cuid())
  employeeId       String
  type             DocumentType
  originalFilename String
  mimeType         String
  fileSize         Int
  uploadedAt       DateTime @default(now())

  storedFilename      String
  fileExtension       String

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
}