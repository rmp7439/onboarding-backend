generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  userId      String   @unique @default(cuid())
  name        String
  mobile      String   @unique
  password    String
  active      Boolean  @default(true)
  isProtected Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  units UserUnit[]
}

model Unit {
  id             String   @id @default(cuid())
  name           String   @unique
  isProtected    Boolean  @default(false)
  requiredFields String[] @default([])
  createdAt      DateTime @default(now())

  users UserUnit[]
}

model UserUnit {
  userId String
  unitId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  unit Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@id([userId, unitId])
}

model Bank {
  id        String   @id @default(cuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Employee {
  id                     String           @id @default(cuid())
  employeeCode           String?          @unique
  status                 EmployeeStatus   @default(PENDING)
  firstName              String
  surname                String
  fatherName             String
  husbandName            String?
  gender                 Gender
  bloodGroup             BloodGroup
  maritalStatus          MaritalStatus    @default(SINGLE)
  education              HighestEducation @default(OTHER)
  dateOfBirth            DateTime
  joiningDate            DateTime
  mobile                 String           @unique
  aadhaar                String           @unique
  pan                    String?          @unique
  uan                    String?
  esic                   String?
  drivingLicence         String?
  permanentAddress       String
  currentAddress         String
  city                   String
  state                  String
  pinCode                String
  permanentPoliceStation String?
  currentCity            String?
  currentState           String?
  currentPinCode         String?
  accountHolderName      String?
  bankName               String
  accountNumber          String
  ifsc                   String
  branch                 String?
  micr                   String?
  emergencyName          String
  emergencyRelation      String
  emergencyPhone         String
  nomineeName            String?
  nomineeRelation        String?
  nomineeMobile          String?
  nomineePercentage      Int?
  selfieFilename         String?
  selfieMimeType         String?
  selfieSize             Int?
  uploadedAt             DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  rejectReason           String?
  correctionRemark       String?
  unit                   String?
  documents              Document[]

  @@index([firstName, surname])
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("ADMIN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Document {
  id               String       @id @default(cuid())
  employeeId       String
  type             DocumentType
  storedFilename   String
  originalFilename String
  mimeType         String
  fileSize         Int
  uploadedAt       DateTime     @default(now())
  fileExtension    String
  employee         Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum EmployeeStatus {
  PENDING
  APPROVED
  REJECTED
  RETURNED_FOR_CORRECTION
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum MaritalStatus {
  SINGLE
  MARRIED
  DIVORCED
  WIDOWED
}

enum HighestEducation {
  ILLITERATE
  PRIMARY
  SECONDARY
  HIGHER_SECONDARY
  ITI
  DIPLOMA
  GRADUATE
  POST_GRADUATE
  DOCTORATE
  OTHER
}

enum DocumentType {
  AADHAAR
  PAN
  DRIVING_LICENSE
  BANK_PASSBOOK
  EDUCATION
  VOTER_ID
  DISCHARGE_BOOK
}

enum BloodGroup {
  A_POSITIVE
  A_NEGATIVE
  B_POSITIVE
  B_NEGATIVE
  AB_POSITIVE
  AB_NEGATIVE
  O_POSITIVE
  O_NEGATIVE
}